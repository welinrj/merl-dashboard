# =============================================================================
# .env.example — DoCC M&E Monitoring Platform (DMP) Deployment Variables
# Project: Vanuatu Loss and Damage Fund Development Project
#
# USAGE:
#   cp .env.example .env
#   # Fill in every value below, then run: docker compose up -d --build
#   # NEVER commit the actual .env file to source control.
#
# These variables configure the APPLICATION tier (frontend build + proxy).
# The Supabase BACKEND tier has its own .env inside the official
# supabase/docker distribution — see docs/migration-runbook.md §5 for the
# complete list of backend secrets (POSTGRES_PASSWORD, JWT_SECRET, ANON_KEY,
# SERVICE_ROLE_KEY, etc.) and how to generate them.
# =============================================================================

# ── Supabase connection (baked into the frontend bundle at build time) ───────
# Production (Government server): https://api.dmp.gov.vu  (self-hosted Supabase)
# Staging (Supabase Cloud):       https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://api.dmp.gov.vu

# The Supabase "anon" public API key. Safe to expose in the browser — all data
# access is enforced server-side by Row-Level Security policies.
# Self-hosted: printed when you generate keys per migration runbook §5.2.
# Supabase Cloud: Dashboard → Project Settings → API.
VITE_SUPABASE_ANON_KEY=changeme_anon_key

# ── Redis caching sidecar (optional performance tier) ────────────────────────
# The `cache-service` container serves precomputed, organisation-wide aggregate
# results (Analysis / Dashboard) from Redis so the database doesn't recompute
# them for every user. It reads the anon-granted v_srf_analytics view with the
# key above. The frontend degrades gracefully if this tier is absent.
#
# How long a cached aggregate is served before it is refetched from the DB
# materialized view (seconds).
CACHE_TTL=300
# Shared secret required to POST /api-cache/invalidate (force-drops cached keys,
# e.g. from an admin action). The endpoint fails closed: if this is blank the
# invalidate route is disabled entirely (always 403), so leaving it unset is
# safe. Set it only if you need on-demand invalidation. Generate with:
#   openssl rand -hex 24
CACHE_INVALIDATE_SECRET=

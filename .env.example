# =============================================================================
# .env.example — MERL Dashboard Environment Variables
# Project: Vanuatu Loss and Damage Fund Development Project
#
# USAGE:
#   cp .env.example .env
#   # Edit .env and fill in all values marked  <-- CHANGE THIS
#   # NEVER commit the actual .env file to source control.
#
# All "changeme_*" placeholders MUST be replaced with strong, unique values
# before deploying to any non-development environment.
# =============================================================================


# =============================================================================
# POSTGRESQL
# Primary application database — stores all MERL transactional data.
# =============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=merl_dashboard
POSTGRES_USER=merl_user
POSTGRES_PASSWORD=changeme_strong_password          # <-- CHANGE THIS (min 32 chars)

# Optional: separate read-replica for reporting queries (leave empty to use primary)
POSTGRES_REPLICA_HOST=
POSTGRES_REPLICA_PORT=5432


# =============================================================================
# CLICKHOUSE
# Analytics database — receives CDC replication from PostgreSQL via PeerDB.
# Used for KPI computations, dashboard queries, and aggregations.
# =============================================================================

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000                                # Native TCP protocol
CLICKHOUSE_HTTP_PORT=8123                           # HTTP interface (used by backup DAG)
CLICKHOUSE_DB=merl_analytics
CLICKHOUSE_USER=merl_ch_user
CLICKHOUSE_PASSWORD=changeme_ch_password            # <-- CHANGE THIS

# ClickHouse database for PeerDB-replicated tables (ch_merl schema)
CLICKHOUSE_MERL_DB=ch_merl


# =============================================================================
# KEYCLOAK (Identity and Access Management)
# Provides SSO, OIDC/OAuth2, and role-based access control.
# =============================================================================

KEYCLOAK_URL=http://keycloak:8180
KEYCLOAK_REALM=merl-dashboard
KEYCLOAK_CLIENT_ID=merl-api
KEYCLOAK_CLIENT_SECRET=changeme_client_secret       # <-- CHANGE THIS (UUID or 64-char random)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_admin_password     # <-- CHANGE THIS

# Frontend OIDC client (public client, no secret required)
KEYCLOAK_FRONTEND_CLIENT_ID=merl-frontend


# =============================================================================
# BACKEND (FastAPI)
# =============================================================================

# 64-character random string used for JWT signing and session encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_64char_random_string_replace_this_now  # <-- CHANGE THIS

# Comma-separated list of origins allowed by the CORS middleware.
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# Algorithm used for JWT tokens (HS256 or RS256 if using Keycloak public key)
JWT_ALGORITHM=HS256
# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Internal token used by Airflow DAGs to call /api/internal/* endpoints
INTERNAL_SYNC_TOKEN=changeme_internal_sync_token    # <-- CHANGE THIS


# =============================================================================
# REDIS
# Used by: Celery (Airflow + Superset async), application caching.
# =============================================================================

REDIS_URL=redis://redis:6379/0

# Separate logical databases for different consumers
REDIS_AIRFLOW_DB=0
REDIS_SUPERSET_CACHE_DB=1
REDIS_SUPERSET_RESULTS_DB=2
REDIS_APP_CACHE_DB=3


# =============================================================================
# AIRFLOW
# Workflow orchestration for data ingestion, KPI computation,
# report generation, backups, and data quality checks.
# =============================================================================

# Fernet key: used to encrypt sensitive values stored in Airflow's DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=changeme_fernet_key_base64       # <-- CHANGE THIS (Fernet base64 key)

# Secret key for Airflow's Flask webserver sessions.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=changeme_airflow_secret          # <-- CHANGE THIS

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_airflow_password    # <-- CHANGE THIS
AIRFLOW_ADMIN_FIRSTNAME=MERL
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.gov.vu

# Airflow metadata database (can share the PostgreSQL instance, separate DB recommended)
AIRFLOW_DB=airflow_metadata

# Number of parallel task instances
AIRFLOW__CORE__PARALLELISM=8
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=4

# Timezone for the Airflow scheduler UI
AIRFLOW__CORE__DEFAULT_TIMEZONE=Pacific/Efate


# =============================================================================
# SUPERSET
# Business intelligence and dashboard visualisation.
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=changeme_superset_secret        # <-- CHANGE THIS

SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=changeme_superset_password  # <-- CHANGE THIS
SUPERSET_ADMIN_FIRSTNAME=MERL
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.gov.vu

# Publicly accessible URL of Superset (used for alert email links and embedding)
SUPERSET_PUBLIC_URL=http://localhost:8088

# CORS origins for Superset's API (space/comma-separated)
SUPERSET_CORS_ORIGINS=http://localhost,http://localhost:3000

# Cache TTL overrides (seconds)
SUPERSET_CACHE_TTL=600
SUPERSET_DATA_CACHE_TTL=1800

# Set to "true" to skip actually sending alert emails (useful for staging)
SUPERSET_ALERT_DRY_RUN=false


# =============================================================================
# FILE UPLOADS
# =============================================================================

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# Directory where Airflow report DAG saves PDF/Excel files
REPORTS_DIR=/opt/airflow/reports

# Backup storage directory (used by backup_dag.py)
BACKUP_DIR=/backups

# Number of days to retain local backup files before deletion
BACKUP_RETENTION_DAYS=30


# =============================================================================
# EMAIL / SMTP
# Used by Airflow DAGs (report_generation, data_quality_check) and Superset
# alert reports.
# =============================================================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.gov.vu
SMTP_PASSWORD=changeme_smtp_password                # <-- CHANGE THIS
SMTP_FROM=noreply@example.gov.vu

# Comma-separated list of email recipients for automated reports and alerts
REPORT_RECIPIENTS=merl@docc.gov.vu,projects@docc.gov.vu


# =============================================================================
# S3-COMPATIBLE OBJECT STORAGE (OPTIONAL — for offsite backup uploads)
#
# Supported backends: AWS S3, MinIO, Backblaze B2, Wasabi, etc.
# Leave S3_BUCKET empty to disable S3 uploads in the backup DAG.
# =============================================================================

S3_BUCKET=
S3_ENDPOINT=
# For AWS S3 leave S3_ENDPOINT empty; the boto3 default endpoint is used.
# For MinIO: S3_ENDPOINT=http://minio:9000
# For Backblaze B2: S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION is only needed for AWS S3 (not MinIO/B2)
AWS_DEFAULT_REGION=ap-southeast-2


# =============================================================================
# PEERDB (Change Data Capture — PostgreSQL → ClickHouse)
# PeerDB uses these credentials to connect to the source and destination peers.
# The actual connection strings are assembled in peerdb/config.json using
# the POSTGRES_* and CLICKHOUSE_* variables above.
# =============================================================================

# Password for the PeerDB service account (if different from POSTGRES_PASSWORD)
PEERDB_PASSWORD=changeme_peerdb_password            # <-- CHANGE THIS

# PeerDB UI access password
PEERDB_UI_PASSWORD=changeme_peerdb_ui_password      # <-- CHANGE THIS


# =============================================================================
# NGINX / TLS
# These are used if you generate self-signed certs or integrate with certbot.
# =============================================================================

# Domain name for SSL certificate (Let's Encrypt / certbot)
SSL_DOMAIN=merl.example.gov.vu

# Set to "true" once SSL certificates are in place and HTTPS block is active
COOKIE_SECURE=false


# =============================================================================
# DEVELOPMENT OVERRIDES
# Only used in local development; override in docker-compose.override.yml.
# =============================================================================

# Set to "development" or "production"
ENVIRONMENT=development

# Enable verbose SQL logging in the backend
SQL_ECHO=false

# Superset log level: DEBUG, INFO, WARNING, ERROR
SUPERSET_LOG_LEVEL=WARNING

# Airflow log level
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO

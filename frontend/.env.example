# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ── App environment ───────────────────────────────────────────────────────────
# Set to "production" in the production deployment to disable Demo Mode badge
# and demo credential hints.
VITE_APP_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────────
# Replace with your project's URL and anon key from Supabase dashboard.
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Demo account passwords ────────────────────────────────────────────────────
# Used only when VITE_APP_ENV != "production". Choose strong passwords.
VITE_DEMO_ADMIN_PASS=
VITE_DEMO_SENIOR_PASS=
VITE_DEMO_MEO_PASS=
VITE_DEMO_MGR_PASS=
VITE_DEMO_STAFF_PASS=

# ── Demo TOTP fallback ────────────────────────────────────────────────────────
# 6-digit code used as MFA fallback for the admin demo account when no
# Supabase TOTP factor is enrolled. Remove once real MFA is enrolled.
VITE_DEMO_ADMIN_TOTP_CODE=

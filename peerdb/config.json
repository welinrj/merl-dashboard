  "postgresql_setup": {
    "_instructions": [
      "Run these commands on the PostgreSQL source database before starting PeerDB.",
      "1. Enable logical replication in postgresql.conf: wal_level = logical",
      "2. Run the SQL below as a superuser."
    ],
    "setup_sql": [
      "-- Create the publication covering all merl schema tables",
      "CREATE PUBLICATION peerdb_merl_publication FOR TABLES IN SCHEMA merl;",
      "",
      "-- Create a dedicated replication slot (PeerDB can also create this automatically)",
      "SELECT pg_create_logical_replication_slot('peerdb_merl_slot', 'pgoutput');",
      "",
      "-- Grant replication privileges to the merl user",
      "ALTER ROLE merl_user REPLICATION LOGIN;",
      "GRANT USAGE ON SCHEMA merl TO merl_user;",
      "GRANT SELECT ON ALL TABLES IN SCHEMA merl TO merl_user;"
    ]
  },

  "clickhouse_setup": {
    "_instructions": [
      "Run these DDL statements in ClickHouse before starting PeerDB mirrors.",
      "Each table uses ReplacingMergeTree so that CDC UPDATEs are idempotent.",
      "The _peerdb_synced_at column is used as the ReplacingMergeTree version.",
      "The _peerdb_is_deleted column allows PeerDB soft-deletes to propagate."
    ],
    "create_database_sql": "CREATE DATABASE IF NOT EXISTS ch_merl;",
    "notes": [
      "Full DDL for each ch_merl.* table should be placed in database/clickhouse/schema.sql.",
      "Minimum requirement: each table must have an ORDER BY key matching the source PK,",
      "plus _peerdb_synced_at DateTime DEFAULT now() and _peerdb_is_deleted UInt8 DEFAULT 0."
    ]
  }

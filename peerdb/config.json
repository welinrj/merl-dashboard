{
  "_comment": "PeerDB v0.18+ CDC replication configuration for MERL Dashboard",
  "_project": "Vanuatu Loss and Damage Fund Development Project",
  "_doc": "https://docs.peerdb.io/",

  "peers": {
    "source_postgres": {
      "name": "merl_postgres_source",
      "type": "POSTGRES",
      "config": {
        "host": "${POSTGRES_HOST}",
        "port": "${POSTGRES_PORT}",
        "database": "${POSTGRES_DB}",
        "user": "${POSTGRES_USER}",
        "password": "${POSTGRES_PASSWORD}",
        "transaction_snapshot": "",
        "_comment_ssl": "Set ssl_mode to 'require' in production",
        "ssl_mode": "prefer",
        "replication_slot_name": "peerdb_merl_slot",
        "publication_name": "peerdb_merl_publication"
      }
    },
    "destination_clickhouse": {
      "name": "merl_clickhouse_dest",
      "type": "CLICKHOUSE",
      "config": {
        "host": "${CLICKHOUSE_HOST}",
        "port": "${CLICKHOUSE_PORT}",
        "database": "${CLICKHOUSE_DB}",
        "user": "${CLICKHOUSE_USER}",
        "password": "${CLICKHOUSE_PASSWORD}",
        "s3_path": "",
        "s3_region": "",
        "s3_access_key_id": "",
        "s3_secret_access_key": "",
        "_comment_s3": "S3 staging is optional for large initial copies; leave empty for direct TCP"
      }
    }
  },

  "mirrors": [
    {
      "mirror_name": "merl_indicators_cdc",
      "_description": "Replicates merl.indicators → ch_merl.indicators",
      "flow_job_name": "merl_indicators_cdc",
      "source_peer": "merl_postgres_source",
      "destination_peer": "merl_clickhouse_dest",
      "table_mappings": [
        {
          "source_table_identifier": "merl.indicators",
          "destination_table_identifier": "ch_merl.indicators",
          "partition_column": "",
          "columns": []
        }
      ],
      "cdc_flow_options": {
        "sync_mode": "CDC",
        "do_initial_copy": true,
        "snapshot_num_rows_per_partition": 100000,
        "snapshot_max_parallel_workers": 4,
        "snapshot_num_tables_in_parallel": 2,
        "cdc_staging_path": "",
        "soft_delete": true,
        "soft_delete_col_name": "_peerdb_is_deleted",
        "synced_at_col_name": "_peerdb_synced_at",
        "max_batch_size": 1000,
        "idle_timeout_seconds": 60,
